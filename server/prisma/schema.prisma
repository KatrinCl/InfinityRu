generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  cartData  Json?
  orders    Order[]
  createdAt DateTime @default(now())
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  composition String
  weight      Int
  weight1     Int
  weight2     Int
  price       Float
  image       String[]
  popular     Boolean  @default(false)
  date        DateTime @default(now())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}

model Order {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  items        Json
  address      Json
  amount       Float
  paymentMethod String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}
